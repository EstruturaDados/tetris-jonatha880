#include <stdio.h>
#include <stdlib.h>

#define TAM_FILA 5
#define TAM_PILHA 3

/* =====================
   Estrutura da Peça
   ===================== */
typedef struct {
    char nome; // I, O, T, L
    int id;    // identificador único
} Peca;

/* =====================
   Estrutura da Fila Circular
   ===================== */
typedef struct {
    Peca dados[TAM_FILA];
    int inicio;
    int fim;
    int quantidade;
} Fila;

/* =====================
   Estrutura da Pilha
   ===================== */
typedef struct {
    Peca dados[TAM_PILHA];
    int topo;
} Pilha;

/* =====================
   Geração de Peças
   ===================== */
Peca gerarPeca(int id) {
    char tipos[] = {'I', 'O', 'T', 'L'};
    Peca p;
    p.nome = tipos[rand() % 4];
    p.id = id;
    return p;
}

/* =====================
   Funções da Fila
   ===================== */
void inicializarFila(Fila *f) {
    f->inicio = 0;
    f->fim = 0;
    f->quantidade = 0;
}

int filaCheia(Fila *f) {
    return f->quantidade == TAM_FILA;
}

int filaVazia(Fila *f) {
    return f->quantidade == 0;
}

void enqueue(Fila *f, Peca p) {
    if (filaCheia(f)) return;
    f->dados[f->fim] = p;
    f->fim = (f->fim + 1) % TAM_FILA;
    f->quantidade++;
}

Peca dequeue(Fila *f) {
    Peca removida = f->dados[f->inicio];
    f->inicio = (f->inicio + 1) % TAM_FILA;
    f->quantidade--;
    return removida;
}

/* =====================
   Funções da Pilha
   ===================== */
void inicializarPilha(Pilha *p) {
    p->topo = -1;
}

int pilhaCheia(Pilha *p) {
    return p->topo == TAM_PILHA - 1;
}

int pilhaVazia(Pilha *p) {
    return p->topo == -1;
}

void push(Pilha *p, Peca x) {
    if (!pilhaCheia(p))
        p->dados[++p->topo] = x;
}

Peca pop(Pilha *p) {
    return p->dados[p->topo--];
}

/* =====================
   Exibição do Estado
   ===================== */
void exibirEstado(Fila *f, Pilha *p) {
    printf("\n============================\n");
    printf("Estado atual:\n\n");

    printf("Fila de peças\t");
    for (int i = 0; i < f->quantidade; i++) {
        int pos = (f->inicio + i) % TAM_FILA;
        printf("[%c %d] ", f->dados[pos].nome, f->dados[pos].id);
    }

    printf("\nPilha de reserva\t(Topo -> Base): ");
    if (pilhaVazia(p)) {
        printf("[vazia]");
    } else {
        for (int i = p->topo; i >= 0; i--) {
            printf("[%c %d] ", p->dados[i].nome, p->dados[i].id);
        }
    }

    printf("\n============================\n");
}

/* =====================
   Troca simples (frente ↔ topo)
   ===================== */
void trocarAtual(Fila *f, Pilha *p) {
    if (filaVazia(f) || pilhaVazia(p)) {
        printf("\nTroca não possível.\n");
        return;
    }

    int posFila = f->inicio;
    Peca temp = f->dados[posFila];
    f->dados[posFila] = p->dados[p->topo];
    p->dados[p->topo] = temp;

    printf("\nTroca simples realizada.\n");
}

/* =====================
   Troca múltipla (3 peças)
   ===================== */
void trocaMultipla(Fila *f, Pilha *p) {
    if (f->quantidade < 3 || p->topo + 1 < 3) {
        printf("\nTroca múltipla não possível.\n");
        return;
    }

    for (int i = 0; i < 3; i++) {
        int posFila = (f->inicio + i) % TAM_FILA;
        Peca temp = f->dados[posFila];
        f->dados[posFila] = p->dados[p->topo - i];
        p->dados[p->topo - i] = temp;
    }

    printf("\nTroca múltipla realizada entre fila e pilha.\n");
}

/* =====================
   Programa Principal
   ===================== */
int main() {
    Fila fila;
    Pilha pilha;
    int opcao;
    int idAtual = 0;

    srand(42);

    inicializarFila(&fila);
    inicializarPilha(&pilha);

    // Inicializa fila cheia
    for (int i = 0; i < TAM_FILA; i++) {
        enqueue(&fila, gerarPeca(idAtual++));
    }

    do {
        exibirEstado(&fila, &pilha);

        printf("\nOpções disponíveis:\n");
        printf("1 - Jogar peça da frente da fila\n");
        printf("2 - Enviar peça da fila para a pilha\n");
        printf("3 - Usar peça da pilha de reserva\n");
        printf("4 - Trocar peça da frente da fila com topo da pilha\n");
        printf("5 - Trocar os 3 primeiros da fila com a pilha\n");
        printf("0 - Sair\n");
        printf("Opção escolhida: ");
        scanf("%d", &opcao);

        switch (opcao) {

            case 1: {
                Peca p = dequeue(&fila);
                printf("\nPeça jogada: [%c %d]\n", p.nome, p.id);
                enqueue(&fila, gerarPeca(idAtual++));
                break;
            }

            case 2: {
                if (!pilhaCheia(&pilha)) {
                    Peca p = dequeue(&fila);
                    push(&pilha, p);
                    printf("\nPeça reservada: [%c %d]\n", p.nome, p.id);
                    enqueue(&fila, gerarPeca(idAtual++));
                } else {
                    printf("\nPilha cheia.\n");
                }
                break;
            }

            case 3: {
                if (!pilhaVazia(&pilha)) {
                    Peca p = pop(&pilha);
                    printf("\nPeça usada da reserva: [%c %d]\n", p.nome, p.id);
                    enqueue(&fila, gerarPeca(idAtual++));
                } else {
                    printf("\nPilha vazia.\n");
                }
                break;
            }

            case 4:
                trocarAtual(&fila, &pilha);
                break;

            case 5:
                trocaMultipla(&fila, &pilha);
                break;

            case 0:
                printf("\nEncerrando o programa...\n");
                break;

            default:
                printf("\nOpção inválida.\n");
        }

    } while (opcao != 0);

    return 0;
}